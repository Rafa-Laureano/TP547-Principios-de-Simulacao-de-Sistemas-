      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "N=1000\n",
        "x=np.random.uniform(0,1,N)\n",
        "Xinv=np.sqrt(x)\n",
        "\n",
        "print(Xinv)\n",
        "\n",
        "X=np.arange(0,1,0.01)\n",
        "fx=2*X\n",
        "\n",
        "plt.plot(X,fx)\n",
        "plt.hist(Xinv,bins=30,density=True)\n",
        "plt.show()"
      ]
